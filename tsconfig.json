{
    "compilerOptions": {
        "strict": true,
        "target": "es2017",
        "module": "commonjs",
        "moduleResolution": "node",
        "outDir": "dist",
        "rootDir": "src",
        "sourceMap": false,
        "declaration": true,
        "declarationMap": true,
        "skipLibCheck": true,
        "incremental": true,
        "forceConsistentCasingInFileNames": true,
        "noFallthroughCasesInSwitch": true,
        "noImplicitReturns": true,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "lib": ["es2019"],
        "types": ["node", "jest"]
    },
    "include": ["src"],
    "exclude": ["node_modules", "dist", "**/*.spec.ts", "**/*.test.ts"]
}
